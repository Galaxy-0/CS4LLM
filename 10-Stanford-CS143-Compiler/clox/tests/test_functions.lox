// Functions
fun greet(name) {
    print "Hello, " + name + "!";
}
greet("world");

// Return values
fun add(a, b) {
    return a + b;
}
print add(3, 4);

// Recursion - fibonacci
fun fib(n) {
    if (n <= 1) return n;
    return fib(n - 1) + fib(n - 2);
}
print fib(10);

// Closures
fun makeCounter() {
    var count = 0;
    fun increment() {
        count = count + 1;
        print count;
    }
    return increment;
}

var counter = makeCounter();
counter();
counter();
counter();

// Closure capturing loop variable
fun makeAdder(x) {
    fun adder(y) {
        return x + y;
    }
    return adder;
}
var add5 = makeAdder(5);
print add5(10);
print add5(20);

// Native function
print clock();

print "all function tests passed";
