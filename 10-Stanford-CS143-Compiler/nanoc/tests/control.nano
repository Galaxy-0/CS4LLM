fn abs(x: int): int {
    if (x < 0) {
        return -x;
    }
    return x;
}

fn main(): int {
    // if/else
    print abs(-42);
    print abs(7);

    // while loop
    var sum: int = 0;
    var i: int = 1;
    while (i <= 100) {
        sum = sum + i;
        i = i + 1;
    }
    print sum;

    // for loop
    var product: int = 1;
    for (var j: int = 1; j <= 10; j = j + 1) {
        product = product * j;
    }
    print product;

    // bool
    print 3 > 2;
    print 1 == 2;

    return 0;
}
